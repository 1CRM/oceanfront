{
  "name": "oceanfront-workflow-canvas",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "main": "dist/oceanfront-workflow-canvas.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/oceanfront-workflow-canvas.mjs",
      "default": "./dist/oceanfront-workflow-canvas.mjs"
    },
    "./css": "./dist/oceanfront-workflow-canvas.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "build-dev": "vite build -m development",
    "package": "yarn pack",
    "clean": "rm -rf .turbo .vite node_modules dist",
    "coverage": "vitest run --coverage",
    "demo": "vite build -m development --watch",
    "lint": "eslint src --ext .ts,.vue",
    "test": "vitest --watch=false"
  },
  "peerDependencies": {
    "oceanfront": "*",
    "vue": "~3.5.25"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-vue": "~6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/compiler-dom": "~3.5.34",
    "@vue/test-utils": "2.4.10",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.2.0",
    "jsdom": "^27.2.0",
    "oceanfront": "*",
    "prettier": "^3.7.4",
    "tslib": "~2.8.1",
    "typescript": "~5.9.3",
    "vite": "~8.0.13",
    "@microsoft/api-extractor": "^7.58.7",
    "@vue/language-core": "~3.3.0",
    "unplugin-dts": "~1.0.1",
    "vitest": "^4.1.7",
    "vue": "~3.5.25",
    "vue-eslint-parser": "^10.4.0"
  },
  "sideEffects": [
    "*.css",
    "*.scss"
  ]
}
