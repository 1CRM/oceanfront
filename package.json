{
  "private": true,
  "version": "0.0.1",
  "name": "oceanfront-repo",
  "packageManager": "yarn@1.22.17",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build --no-daemon",
    "build-dev": "turbo run build-dev --no-daemon",
    "package": "turbo run package",
    "clean": "turbo run clean && rm -rf node_modules",
    "coverage": "turbo run coverage --no-daemon",
    "demo": "turbo run demo --no-daemon",
    "lint": "turbo run lint --no-daemon",
    "test": "turbo run test --no-daemon"
  },
  "devDependencies": {
    "turbo": "^2.6.2"
  },
  "resolutions": {
    "vue": "~3.5.25",
    "minimatch": "^10.2.4",
    "lodash": "^4.17.23",
    "@microsoft/api-extractor": "^7.57.7",
    "@microsoft/tsdoc-config": "~0.18.1",
    "@rushstack/node-core-library": "5.20.3",
    "ajv-formats/ajv": "^8.18.0",
    "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.5.0",
    "brace-expansion": "^5.0.2"
  }
}
